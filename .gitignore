recon/cpp2il-out/
recon/Plugins/

# IDE / OS
.vs/
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Logs
*.log
# Added by code-review-graph
.code-review-graph/

# Backup files (e.g. .claude/settings.json.bak created during plugin install)
*.bak

docs/recon/

# brainstorming visual companion mockups
.superpowers/

# BepInEx staging symlink (local, per-worktree)
tools/BepInEx-stage

# Python bytecode (tools/release/*.py run locally)
__pycache__/
*.pyc

# Local dev symlinks (machine-specific; created by setup-dev-env.sh / build-bundle.sh — never commit)
.local/
src/samples
